<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog
        id="manageProjectsDialog"
        contentWidth="55%" contentHeight="60%">
        <content>
            <Text text="Manage Projects" class="sapUiSmallMarginBottom sapUiSmallMarginTop sapUiTinyMarginBegin sapUiTinyMarginEnd"/>
        </content>
        <beginButton>
            <!-- <Button text="Add 2" press=".onAddCustomer"/> -->
            <Button text="OK" core:require="{ handler: 'hpbuysell/mdm/usermgmtui/ext/fragment/CustMngProjColumn'}" press="handler.onOkProjects" />
        </beginButton>
        <endButton>
            <!-- <Button text="Cancel" press=".onCloseDialog"/> -->
            <Button text="Cancel" core:require="{ handler: 'hpbuysell/mdm/usermgmtui/ext/fragment/CustMngProjColumn'}" press="handler.onCancelDialog" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>