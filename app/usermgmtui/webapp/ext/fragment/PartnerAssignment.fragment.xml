<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog
        id="partnerAssignmentDialog"
        contentWidth="55%" contentHeight="60%">
        <content>
            <VBox class="sapUiSmallMargin">
                <SearchField width="100%" placeholder='Search by ID or Name... e.g. "acme"' core:require="{ handler: 'hpbuysell/mdm/usermgmtui/ext/controller/PartnerAssignment'}" liveChange="handler.onSearchCustomer" />
                <Table id="partnerTable" mode="SingleSelectMaster" class="sapUiSmallMarginTop" />
            </VBox>
        </content>
        <beginButton>
            <!-- <Button text="Add 2" press=".onAddCustomer"/> -->
            <Button text="OK" core:require="{ handler: 'hpbuysell/mdm/usermgmtui/ext/controller/PartnerAssignment'}" press="handler.onAddPartner" />
        </beginButton>
        <endButton>
            <!-- <Button text="Cancel" press=".onCloseDialog"/> -->
            <Button text="Cancel" core:require="{ handler: 'hpbuysell/mdm/usermgmtui/ext/controller/PartnerAssignment'}" press="handler.onCancelDialog" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>