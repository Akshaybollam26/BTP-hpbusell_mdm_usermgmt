{
  "name": "BTP-hpbuysell_mdm_UserMgmt",
  "version": "1.0.0",
  "dependencies": {
    "@sap/cds": "^9"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.17.0",
    "rimraf": "^5.0.5",
    "mbt": "^1.2.49"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-usermgmtui": "cds watch --open hpbuysell.mdm.usermgmtui/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy BTP-hpbuysell_mdm_UserMgmt --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/usermgmtui"
  ]
}
